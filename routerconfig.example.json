{
    "routers": [
        "Ollama",
        "OpenRouter",
        "LiteLLM",
        "Anthropic"
    ],
    "tool-run": {
        "litellm-openai": "<OPENAI_API_KEY> LITELLM_DROP_PARAMS=true litellm --model openai/gpt-5.2-codex",
        "ollama-qwen3-coder": "ollama run --model qwen3-coder"
    },
    "Anthropic-settings": {
        "baseurl": "https://api.anthropic.com",
        "auth_token": "",
        "api_key": "",
        "models": [
            "claude-sonnet-4-6",
            "claude-opus-4-6",
            "claude-haiku-4-5-20251001"
        ]
    },
    "OpenRouter-settings": {
        "baseurl": "https://openrouter.ai/api",
        "auth_token": "<AUTH_TOKEN>",
        "api_key": "",
        "models": [
            "qwen/qwen3.6-plus:free",
            "qwen/qwen3-coder:free",
            "qwen/qwen3-next-80b-a3b-instruct:free",
            "nvidia/nemotron-3-nano-30b-a3b:free",
            "stepfun/step-3.5-flash:free",
            "nvidia/nemotron-3-super-120b-a12b:free",
            "glm-4.7:cloud"
        ]
    },
    "Ollama-settings": {
        "baseurl": "http://localhost:11434",
        "auth_token": "ollama",
        "api_key": "",
        "models": [
            "qwen3-coder:480b-cloud",
            "kimi-k2.5:cloud",
            "gemini-3-flash-preview:cloud",
            "gpt-oss:120b-cloud",
            "deepseek-v3.2:cloud",
            "deepseek-v3.1:671b-cloud",
            "glm-5:cloud",
            "minimax-m2.5:cloud",
            "nemotron-3-super:cloud",
            "qwen3-next:cloud",
            "devstral-2:cloud"
        ]
    },
    "LiteLLM-settings": {
        "baseurl": "http://localhost:4000",
        "auth_token": "",
        "api_key": "",
        "models": [
            "openai/gpt-5.2-codex",
            "openai/gpt-5.3"
        ],
        "post_run": "litellm-openai"
    },
    "claude-effort-levels": [
        "low",
        "medium",
        "high",
        "max"
    ],
    "claude-internalbehaviour": [
        "sonnet[1m]",
        "gpt-5.2-codex"
    ]
}